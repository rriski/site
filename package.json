{
  "name": "site",
  "license": "MIT",
  "author": "Timo Riski",
  "scripts": {
    "develop": "gatsby develop",
    "serve": "gatsby serve",
    "ssr": "npm run build && npm run serve",
    "format": "prettier --write src/**/*.js src/**/**/*.js",
    "lint": "eslint --ignore-path .gitignore src/",
    "lint:fix": "eslint --ignore-path .gitignore src/ --fix",
    "build:dir": "mkdirp ./public/icons/",
    "build:favicons": "node scripts/favicons",
    "build": "npm run build:dir && npm run build:favicons && gatsby build"
  },
  "dependencies": {
    "framer-motion": "^10.16.4",
    "gatsby": "5.12.9",
    "gatsby-plugin-image": "^3.12.3",
    "gatsby-plugin-offline": "6.12.3",
    "gatsby-plugin-sharp": "5.12.3",
    "gatsby-plugin-sitemap": "6.12.3",
    "gatsby-plugin-styled-components": "^6.12.0",
    "gatsby-remark-copy-linked-files": "6.12.0",
    "gatsby-remark-images": "7.12.3",
    "gatsby-source-filesystem": "5.12.1",
    "gatsby-transformer-json": "5.12.0",
    "gatsby-transformer-remark": "6.12.3",
    "gatsby-transformer-sharp": "5.12.3",
    "get-scrollbar-width": "1.0.5",
    "intersection-observer": "0.12.2",
    "prop-types": "15.8.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-icons": "4.11.0",
    "sharp": "^0.32.6",
    "styled-components": "^6.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.2",
    "@babel/eslint-parser": "^7.22.15",
    "@netlify/plugin-lighthouse": "^5.0.0",
    "babel-preset-gatsby": "^3.12.1",
    "eslint": "^8.52.0",
    "eslint-config-prettier": "9.0.0",
    "eslint-plugin-import": "2.29.0",
    "eslint-plugin-jsx-a11y": "6.7.1",
    "eslint-plugin-prettier": "5.0.1",
    "eslint-plugin-react": "7.33.2",
    "favicons": "7.1.4",
    "gatsby-plugin-eslint": "^4.0.4",
    "mkdirp": "3.0.1",
    "node-gyp": "9.4.1",
    "postcss": "^8.4.31",
    "prettier": "3.0.3"
  }
}
